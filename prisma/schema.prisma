// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  firstname    String
  lastname     String
  email        String   @unique
  location     String
  phone        String
  password     String
  role         Role     @default(PATIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profilePhoto String?

  // Relationships
  sessions       Session[] // User sessions
  tokens         Token[] // Email verification, password reset
  PatientProfile PatientProfile?

  @@index([email])
  @@index([role])
}

model PatientProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  specialties       String[]
  yearsOfExperience Int
  educationLevel    String
  institution       String
  totalPatients     Int?
  perHourRate       BigInt
  daysOfOperation   String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Appointment {
  id                   String             @id @default(uuid())
  appointmentSessionId String             @unique
  appointmentSession   AppointmentSession @relation(fields: [appointmentSessionId], references: [id])
  context              String
  date                 DateTime
  time                 DateTime
  conditionTitle       String
  images               String[]
  patientId            String
  doctorId             String
  status               AppointmentStatus  @default(PENDING)
  type                 AppointmentType    @default(IN_PERSON)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  appointmentLogs      AppointmentLog[]
  payment              payment?
}

model AppointmentLog {
  id            String            @id @default(uuid())
  appointmentId String            @unique
  status        AppointmentStatus
  changedTo     AppointmentStatus
  changedBy     String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  // RELATIONS
  appointment   Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model AppointmentSession {
  id           String       @id @default(uuid())
  startTime    DateTime
  endTime      DateTime
  date         DateTime
  rating       Int?
  notes        String
  prescription String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  appointment  Appointment?
}

model payment {
  id            String   @id @default(uuid())
  total         BigInt
  appointmentId String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // RELATIONS
  appointment Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  transaction Transaction?
}

model Transaction {
  id        String        @id @default(uuid())
  paymentId String        @unique
  amount    Float
  reference String        @unique
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  payment payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([sessionToken])
}

model Token {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

// ENUMS
enum Role {
  DOCTOR
  PATIENT
}

enum AppointmentStatus {
  PENDING
  RESCHEDULED
  APPROVED
}

enum AppointmentType {
  IN_PERSON
  VIRTUAL
}
