// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(uuid())
  username      String
  email         String     @unique
  password      String
  role          Role       @default(PATIENT)
  country       String
  gender        GenderType
  city          String
  phone         String?
  timezone      String     @default("UTC")
  photo         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  // profilePhoto    String?
  // state           String
  emailVerified DateTime?

  // Relationships
  sessions        Session[] // User sessions
  tokens          Token[] // Email verification, password reset
  patientProfile  PatientProfile?
  doctorProfile   DoctorProfile?
  appointmentLogs AppointmentLog[]

  @@index([email])
  @@index([role])
  @@map("users")
}

enum GenderType {
  MALE
  FEMALE
}

model PatientProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  dateOfBirth           DateTime
  bloodType             String?
  allergies             String[]
  medicalConditions     String[]
  emergencyContactPhone String?
  emergencyContactName  String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // RELATIONS
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
}

model DoctorProfile {
  id                     String            @id @default(uuid())
  userId                 String            @unique
  yearsOfExperience      Int
  educationLevel         String
  institution            String
  perHourRate            Int
  totalRatings           Int               @default(0)
  averageRating          Float?            @default(0)
  appointmentSlotMinutes Int               @default(60)
  bio                    String?
  published              Boolean           @default(false)
  specialties            String[]
  languages              String[]
  modeOfConsultation     consultationTypes @default(IN_PERSON)
  nextAvailableAt        DateTime? // UTC — first bookable slot >= now()

  // specialties            String[]
  // totalPatients          Int?
  // daysOfOperation        String[]

  // restrict it to only in_person, virtual, or both
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  reviews      Review[]
  availability DoctorAvailability[]

  @@index([published, nextAvailableAt]) // NEW — for list sort
  @@index([userId])
}

model DoctorAvailability {
  id        String           @id @default(uuid())
  doctorId  String
  kind      AvailabilityKind // ← NEW: the discriminator
  weekday   Int? // 0–6, only used when kind = RECURRING
  date      DateTime? // calendar date, only used when kind = OVERRIDE or BLACKOUT
  startTime String // "HH:mm"   — ignored on BLACKOUT (full-day block)
  endTime   String // "HH:mm"   — ignored on BLACKOUT (full-day block)
  isActive  Boolean          @default(true) // ← NEW: soft-disable a rule without deleting it
  doctor    DoctorProfile    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, kind, weekday])
  @@index([doctorId, kind, date])
}

enum consultationTypes {
  VIRTUAL
  IN_PERSON
  BOTH
}

model Appointment {
  id                   String            @id @default(uuid())
  appointmentSessionId String?           @unique
  context              String
  scheduledStartAt     DateTime
  scheduledEndAt       DateTime
  conditionTitle       String
  images               String[]
  patientId            String
  idempotencyKey       String?           @unique
  // Money in pesewas
  priceAtBookingMinor  Int
  doctorId             String
  status               AppointmentStatus @default(PENDING)
  type                 AppointmentType   @default(IN_PERSON)

  // ── 2. NEW: structured cancellation / rejection reason. ──
  reason      String? // free text; displayed back to patient
  cancelledBy String? // userId of the actor who cancelled

  // ── 3. NEW: reschedule proposal — the doctor's suggested new slot. ──
  proposedStartAt DateTime?
  proposedEndAt   DateTime?
  proposedAt      DateTime?
  proposalRound   Int       @default(0) // capped at 2 (one round each side)

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  appointmentLogs    AppointmentLog[]
  payment            Payment?
  appointmentSession AppointmentSession? @relation(fields: [appointmentSessionId], references: [id])
  doctor             DoctorProfile       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient            PatientProfile      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reviews            Review[]

  @@unique([doctorId, scheduledStartAt])
  @@index([status])
  @@index([doctorId, scheduledStartAt])
  @@index([patientId, scheduledStartAt])
  @@index([doctorId, status])
  @@index([patientId, status])
}

model Review {
  id            String @id @default(uuid())
  doctorId      String
  rating        Int?
  notes         String
  appointmentId String

  doctor      DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppointmentLog {
  id             String            @id @default(uuid())
  appointmentId  String
  previousStatus AppointmentStatus
  newStatus      AppointmentStatus
  changedBy      String

  reason   String?
  metadata Json?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  // RELATIONS
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  changedByUser User        @relation(fields: [changedBy], references: [id], onDelete: Cascade)

  @@index([appointmentId, createdAt])
}

model AppointmentSession {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  date      DateTime

  prescription String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  appointment  Appointment?
}

model Payment {
  id            String   @id @default(uuid())
  // Money in pesewas
  total         Int
  appointmentId String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // RELATIONS
  appointment Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  transaction Transaction?

  @@map("payments")
}

model Transaction {
  id          String        @id @default(uuid())
  paymentId   String        @unique
  //money in pesewas
  amountMinor Int
  reference   String        @unique
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([sessionToken])
  @@index([expires])
}

model Token {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires   DateTime
  type      TokenType @default(EMAIL_VERIFICATION)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@index([token])
}

// ENUMS
enum Role {
  DOCTOR
  PATIENT
}

enum TokenType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

enum AppointmentStatus {
  PENDING
  RESCHEDULED
  APPROVED
  IN_SESSION
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentType {
  IN_PERSON
  VIRTUAL
}

enum AvailabilityKind {
  RECURRING // repeats every week
  OVERRIDE // replaces the recurring rules for one specific date
  BLACKOUT // blocks the doctor out for one specific date
}
